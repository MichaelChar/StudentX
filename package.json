{
  "name": "student-directory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run validate:tests && npm run validate:flashcards && npm run validate:notes",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cf:build": "opennextjs-cloudflare build",
    "deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "preview": "npm run cf:build && opennextjs-cloudflare preview",
    "practice:manifest": "node scripts/generate-practice-manifest.mjs",
    "validate:tests": "node scripts/validate-tests.mjs",
    "flashcards:manifest": "node scripts/generate-flashcards-manifest.mjs",
    "validate:flashcards": "node scripts/validate-flashcards.mjs",
    "notes:manifest": "node scripts/generate-notes-manifest.mjs",
    "validate:notes": "node scripts/validate-notes.mjs",
    "resources:manifest": "node scripts/generate-resources-manifest.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.0",
    "d3-geo": "^3.1.1",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "motion": "^12.40.0",
    "next": "^16.2.6",
    "next-intl": "^4.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "resend": "^4.0.0",
    "stripe": "^22.0.0",
    "topojson-client": "^3.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@swc/helpers": "^0.5.21",
    "@tailwindcss/postcss": "^4",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "vitest": "^4.1.5",
    "wrangler": "^4.80.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "esbuild": "^0.25.0"
  }
}
