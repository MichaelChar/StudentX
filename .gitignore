# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# Public NEXT_PUBLIC_* are tracked so Cloudflare Workers Builds (and any other
# build env) inline them into the client bundle without per-dashboard config.
# Same values are mirrored in wrangler.jsonc:vars for Worker runtime.
!.env.production

# vercel
.vercel

# cloudflare / opennext build outputs
/.open-next/
/.wrangler/
/.tmp-dryrun/

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code (sub-agent worktrees)
.claude/worktrees/
